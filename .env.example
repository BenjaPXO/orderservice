# App
NODE_ENV=development
PORT=3000
APP_CORS_ORIGIN=https://your-vercel-app.vercel.app

# API Key — shared secret for Vercel → Backend communication (Epic 3 Task 1)
API_KEY=replace-with-strong-secret

# Database (Supabase PostgreSQL)
# Prod: puerto 6543 (connection pooling via Supavisor)
# Migraciones: puerto 5432 (direct connection)
DATABASE_URL=postgresql://postgres:PASSWORD@db.REF.supabase.co:6543/postgres
DATABASE_SSL=true

# Redis / BullMQ (Task 2)
REDIS_URL=redis://localhost:6379

# Thirdweb — server-side wallet for settlement (Task 6)
THIRDWEB_CLIENT_ID=
THIRDWEB_ADMIN_PRIVATE_KEY=
THIRDWEB_SECRET_KEY=

# Blockchain — Polygon (Task 4 + Task 6)
FORCE_POLYGON_MAINNET=false
PXO_TOKEN_CONTRACT_ADDRESS=
WALLET_PRIVATE_KEY=
# Platform deposit wallet — users send USDt/PXO here (Task 3)
DEPOSIT_WALLET_ADDRESS=0x...
# Polygon RPC for on-chain verification via viem (Task 4)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
PLATFORM_CHAIN_ID=137

# Binance (Task 5)
BINANCE_API_BASE_URL=https://api.binance.com/api/v3
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Cron (Supabase free-tier keep-alive)
CRON_SECRET=
CRON_KEEPALIVE_PATTERN=0 */12 * * *
